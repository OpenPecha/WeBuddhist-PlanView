  "2": [
    {
      "time_stamp": 222.76182404196166,
      "text": " Tikamātikā. ^1-0a-22\n\n\n#### Dukamātikā ^1-0b-0\n\n\n##### Hetugocchakaṃ ^1-0b-1-0\n\n\n",
