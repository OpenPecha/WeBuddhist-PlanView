      "end": 2225
    },
    {
      "time_stamp": 184.35859517738342,
      "text": " 19. (Ka) atītārammaṇā dhammā.\n(Kha) anāgatārammaṇā dhammā.\n(Ga) paccuppannārammaṇā dhammā. ^1-0a-19\n\n\n",
      "start": 2226,
      "end": 2328
    },
    {
      "time_stamp": 193.1584168664856,
      "text": " 20. (Ka) ajjhattā dhammā.\n(Kha) bahiddhā dhammā.\n(Ga) ajjhattabahiddhā dhammā. ^1-0a-20\n\n\n",
      "start": 2329,
      "end": 2419
    },
    {
      "time_stamp": 201.07762311062623,
      "text": " 21. (Ka) ajjhattārammaṇā dhammā.\n(Kha) bahiddhārammaṇā dhammā.\n(Ga) ajjhattabahiddhārammaṇā dhammā. ^1-0a-21\n\n\n",
      "start": 2420,
      "end": 2531
    },
    {
      "time_stamp": 211.2784670629425,
      "text": " 22. (Ka) sanidassanasappaṭighā dhammā.\n(Kha) anidassanasappaṭighā dhammā.\n(Ga) anidassanaappaṭighā [anidassanāppaṭighā (syā.)] dhammā.\n\n\n",
      "start": 2532,
      "end": 2669
    }
