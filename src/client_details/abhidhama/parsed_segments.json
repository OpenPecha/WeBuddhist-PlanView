{
  "1": [
    {
      "time_stamp": 8.892208,
      "text": " 1. (Ka) kusalā dhammā.\n(Kha) akusalā dhammā.\n(Ga) abyākatā dhammā. ^1-0a-1\n\n\n",
      "start": 175,
      "end": 252
    },
    {
      "time_stamp": 15.41919879019165,
      "text": " 2. (Ka) sukhāya vedanāya sampayuttā dhammā.\n(Kha) dukkhāya vedanāya sampayuttā dhammā.\n(Ga) adukkhamasukhāya vedanāya sampayuttā dhammā. ^1-0a-2\n\n\n",
      "start": 253,
      "end": 400
    },
    {
      "time_stamp": 30.29979689128113,
      "text": " 3. (Ka) vipākā dhammā.\n(Kha) vipākadhammadhammā.\n(Ga) nevavipākanavipākadhammadhammā. ^1-0a-3\n\n\n",
      "start": 401,
      "end": 497
    },
    {
      "time_stamp": 39.92348295422363,
      "text": " 4. (Ka) upādiṇṇupādāniyā [upādinnupādāniyā (syā.)] dhammā.\n(Kha) anupādiṇṇupādāniyā dhammā.\n(Ga) anupādiṇṇaanupādāniyā [anupādinnānupādāniyā (syā.)] dhammā. ^1-0a-4\n\n\n",
      "start": 498,
      "end": 665
    },
    {
      "time_stamp": 51.18749785504151,
      "text": " 5. (Ka) saṃkiliṭṭhasaṃkilesikā dhammā.\n(Kha) asaṃkiliṭṭhasaṃkilesikā dhammā.\n(Ga) asaṃkiliṭṭhaasaṃkilesikā [asaṃkiliṭṭhāsaṃkilesikā (syā.)] dhammā. ^1-0a-5\n\n\n",
      "start": 666,
      "end": 824
    },
    {
      "time_stamp": 63.36376506866455,
      "text": " 6. (Ka) savitakkasavicārā dhammā.\n(Kha) avitakkavicāramattā dhammā.\n(Ga) avitakkaavicārā [avitakkāvicārā (syā.)] dhammā. ^1-0a-6\n\n\n",
      "start": 825,
      "end": 956
    },
    {
      "time_stamp": 73.76396983024597,
      "text": " 7. (Ka) pītisahagatā dhammā.\n(Kha) sukhasahagatā dhammā.\n(Ga) upekkhāsahagatā dhammā. ^1-0a-7\n\n\n",
      "start": 957,
      "end": 1053
    },
    {
      "time_stamp": 82.85992715640259,
      "text": " 8. (Ka) dassanena pahātabbā dhammā.\n(Kha) bhāvanāya pahātabbā dhammā.\n(Ga) neva dassanena na bhāvanāya pahātabbā dhammā. ^1-0a-8\n\n\n",
      "start": 1054,
      "end": 1185
    },
    {
      "time_stamp": 95.77197415640259,
      "text": " 9. (Ka) dassanena pahātabbahetukā dhammā.\n(Kha) bhāvanāya pahātabbahetukā dhammā.\n(Ga) neva dassanena na bhāvanāya pahātabbahetukā dhammā. ^1-0a-9\n\n\n",
      "start": 1186,
      "end": 1335
    },
    {
      "time_stamp": 111.48575902098084,
      "text": " 10. (Ka) ācayagāmino dhammā.\n(Kha) apacayagāmino dhammā.\n(Ga) nevācayagāmināpacayagāmino [nevācayagāmino nāpacayagāmino (syā.)] dhammā. ^1-0a-10\n\n\n",
      "start": 1336,
      "end": 1483
    },
    {
      "time_stamp": 122.05357595422363,
      "text": " 11. (Ka) sekkhā dhammā.\n(Kha) asekkhā dhammā.\n(Ga) nevasekkhanāsekkhā [nevasekkhānāsekkhā (sī. syā.)] dhammā. ^1-0a-11\n\n\n",
      "start": 1484,
      "end": 1605
    },
    {
      "time_stamp": 130.0055659923706,
      "text": " 12. (Ka) parittā dhammā.\n(Kha) mahaggatā dhammā.\n(Ga) appamāṇā dhammā. ^1-0a-12\n\n\n",
      "start": 1606,
      "end": 1688
    },
    {
      "time_stamp": 137.6388449408722,
      "text": " 13. (Ka) parittārammaṇā dhammā.\n(Kha) mahaggatārammaṇā dhammā.\n(Ga) appamāṇārammaṇā dhammā. ^1-0a-13\n\n\n",
      "start": 1689,
      "end": 1792
    },
    {
      "time_stamp": 146.47128197329712,
      "text": " 14. (Ka) hīnā dhammā.\n(Kha) majjhimā dhammā.\n(Ga) paṇītā dhammā. ^1-0a-14\n\n\n",
      "start": 1793,
      "end": 1869
    },
    {
      "time_stamp": 152.67087109346008,
      "text": " 15. (Ka) micchattaniyatā dhammā.\n(Kha) sammattaniyatā dhammā.\n(Ga) aniyatā dhammā. ^1-0a-15\n\n\n",
      "start": 1870,
      "end": 1964
    },
    {
      "time_stamp": 160.85545410871887,
      "text": " 16. (Ka) maggārammaṇā dhammā.\n(Kha) maggahetukā dhammā.\n(Ga) maggādhipatino dhammā. ^1-0a-16\n\n\n",
      "start": 1965,
      "end": 2060
    },
    {
      "time_stamp": 169.61490003623962,
      "text": " 17. (Ka) uppannā dhammā.\n(Kha) anuppannā dhammā.\n(Ga) uppādino dhammā. ^1-0a-17\n\n\n",
      "start": 2061,
      "end": 2143
    },
    {
      "time_stamp": 176.95135194468688,
      "text": " 18. (Ka) atītā dhammā.\n(Kha) anāgatā dhammā.\n(Ga) paccuppannā dhammā. ^1-0a-18\n\n\n",
