      "text": " 125. (Ka) khanti ca.\n(Kha) soraccañca. ^1-0b-125\n\n\n",
      "start": 12859,
      "end": 12910
    },
    {
      "time_stamp": 1132.3947819637604,
      "text": " 126. (Ka) sākhalyañca.\n(Kha) paṭisanthāro ca [paṭisandhāro ca (ka.)]. ^1-0b-126\n\n\n",
      "start": 12911,
      "end": 12993
    },
    {
      "time_stamp": 1137.505459929428,
      "text": " 127. (Ka) indriyesu aguttadvāratā ca.\n(Kha) bhojane amattaññutā ca. ^1-0b-127\n\n\n",
      "start": 12994,
      "end": 13074
    },
    {
      "time_stamp": 1145.1213890572205,
      "text": " 128. (Ka) indriyesu guttadvāratā ca.\n(Kha) bhojane mattaññutā ca. ^1-0b-128\n\n\n",
      "start": 13075,
      "end": 13153
    },
    {
      "time_stamp": 1152.5847478817443,
      "text": " 129. (Ka) muṭṭhasaccañca.\n(Kha) asampajaññañca. ^1-0b-129\n\n\n",
      "start": 13154,
      "end": 13214
    },
    {
      "time_stamp": 1157.6972710400544,
      "text": " 130. (Ka) sati ca.\n(Kha) sampajaññañca. ^1-0b-130\n\n\n",
      "start": 13215,
      "end": 13267
    },
    {
      "time_stamp": 1161.713881803543,
      "text": " 131. (Ka) paṭisaṅkhānabalañca.\n(Kha) bhāvanābalañca. ^1-0b-131\n\n\n",
      "start": 13268,
      "end": 13333
    },
    {
      "time_stamp": 1167.1234390076295,
      "text": " 132. (Ka) samatho ca.\n(Kha) vipassanā ca. ^1-0b-132\n\n\n",
      "start": 13334,
      "end": 13388
    },
    {
      "time_stamp": 1171.2658509790192,
      "text": " 133. (Ka) samathanimittañca .\n(Kha) paggāhanimittañca. ^1-0b-133\n\n\n",
      "start": 13389,
      "end": 13456
    },
    {
      "time_stamp": 1176.4654210610352,
      "text": " 134. (Ka) paggāho ca.\n(Kha) avikkhepo ca. ^1-0b-134\n\n\n",
      "start": 13457,
      "end": 13511
    },
    {
      "time_stamp": 1180.9933019656678,
      "text": " 135. (Ka) sīlavipatti ca.\n(Kha) diṭṭhivipatti ca. ^1-0b-135\n\n\n",
      "start": 13512,
      "end": 13574
    },
    {
      "time_stamp": 1186.1780327997285,
      "text": " 136. (Ka) sīlasampadā ca.\n(Kha) diṭṭhisampadā ca. ^1-0b-136\n\n\n",
      "start": 13575,
      "end": 13637
    },
    {
      "time_stamp": 1191.8732450572204,
      "text": " 137. (Ka) sīlavisuddhi ca.\n(Kha) diṭṭhivisuddhi ca. ^1-0b-137\n\n\n",
      "start": 13638,
      "end": 13702
    },
    {
      "time_stamp": 1197.0571441182556,
      "text": " 138. (Ka) diṭṭhivisuddhi kho pana.\n(Kha) yathādiṭṭhissa ca padhānaṃ. ^1-0b-138\n\n\n",
      "start": 13703,
      "end": 13784
    },
    {
      "time_stamp": 1203.90551690654,
      "text": " 139. (Ka) saṃvego ca saṃvejaniyesu ṭhānesu.\n(Kha) saṃviggassa ca yoniso padhānaṃ. ^1-0b-139\n\n\n",
      "start": 13785,
      "end": 13879
    },
    {
      "time_stamp": 1214.169413011444,
      "text": " 140. (Ka) asantuṭṭhitā ca kusalesu dhammesu.\n(Kha) appaṭivānitā ca padhānasmiṃ. ^1-0b-140\n\n\n",
      "start": 13880,
      "end": 13972
    },
    {
      "time_stamp": 1223.8664071010894,
      "text": " 141. (Ka) vijjā ca.\n(Kha) vimutti ca. ^1-0b-141\n\n\n",
      "start": 13973,
      "end": 14023
    },
    {
      "time_stamp": 1227.2644560133515,
      "text": " 142. (Ka) khaye ñāṇaṃ.\n(Kha) anuppāde ñāṇanti.\nSuttantikadukamātikā [suttantamātikā (syā.)].\nMātikā niṭṭhitā. ^1-0b-142\n\n\n \n\n\n\n",
